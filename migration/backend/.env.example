# DigiWebDex Backend Environment Variables
# Copy to .env and fill in values

# Server
PORT=3001
NODE_ENV=production
API_URL=http://localhost:3001
SITE_URL=https://digiwebdex.com
FRONTEND_URL=https://digiwebdex.com

# Database
DB_HOST=postgres
DB_PORT=5432
DB_NAME=digiwebdex
DB_USER=digiwebdex
DB_PASSWORD=your_secure_password_here

# JWT Auth
JWT_SECRET=your_very_secure_jwt_secret_minimum_32_chars
JWT_EXPIRES_IN=7d

# Email (Resend or SMTP)
RESEND_API_KEY=re_xxxxxxxxxxxx
SMTP_HOST=smtp.resend.com
SMTP_PORT=587
SMTP_USER=resend
SMTP_PASS=re_xxxxxxxxxxxx

# SMS (BulkSMSBD)
SMS_API_KEY=your_bulksmsbd_api_key
SMS_SENDER_ID=DigiWebDex

# Admin notifications
ADMIN_EMAIL=digiwebdex@gmail.com
ADMIN_PHONE=8801674533303
BACKUP_EMAIL=digiwebdex@gmail.com
HOTLINE=01674533303

# Cron authentication
CRON_SECRET=your_cron_secret_here
