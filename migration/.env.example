# DigiWebDex Environment Configuration
# For isolated VPS deployment - does not conflict with other websites

# ============================================
# Project Identification (UNIQUE PER PROJECT)
# ============================================
PROJECT_NAME=digiwebdex
PROJECT_DIR=/var/www/digiwebdex

# ============================================
# Database Configuration (ISOLATED)
# Use unique database name and port
# ============================================
DB_HOST=localhost
DB_PORT=5433
DB_NAME=digiwebdex_db
DB_USER=digiwebdex_user
DB_PASSWORD=your_unique_secure_password_here

# ============================================
# Backend Configuration (ISOLATED PORT)
# ============================================
BACKEND_PORT=3001
NODE_ENV=production

# ============================================
# Authentication
# ============================================
JWT_SECRET=your_jwt_secret_at_least_32_characters_long
JWT_EXPIRES_IN=7d

# ============================================
# Email Service
# ============================================
RESEND_API_KEY=re_xxxxxxxxxxxx
EMAIL_FROM=DigiWebDex <noreply@digiwebdex.com>
ADMIN_EMAIL=digiwebdex@gmail.com

# ============================================
# SMS Service (optional)
# ============================================
SMS_API_KEY=
SMS_SENDER_ID=DigiWebDex

# ============================================
# URLs
# ============================================
FRONTEND_URL=https://digiwebdex.com
API_URL=https://digiwebdex.com/api

# ============================================
# Logging (ISOLATED TO PROJECT DIRECTORY)
# ============================================
LOG_DIR=/var/www/digiwebdex/logs
LOG_LEVEL=info

# ============================================
# Security
# ============================================
WEBHOOK_SECRET=your_webhook_secret_here
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# ============================================
# Feature Flags
# ============================================
ENABLE_DEBUG_LOGGING=false
ENABLE_RATE_LIMITING=true
ENABLE_AUDIT_LOGGING=true
