# DigiWebDex Production Environment Template
# For SELF-HOSTED VPS deployment (no Supabase)

# Application
NODE_ENV=production
VITE_APP_URL=https://digiwebdex.com

# API Configuration (self-hosted backend)
VITE_API_URL=https://digiwebdex.com/api
VITE_WS_URL=wss://digiwebdex.com/ws

# Database (for backend .env)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=digiwebdex
DB_USER=digiwebdex_user
DB_PASSWORD=your_secure_password_here

# Authentication
JWT_SECRET=your_jwt_secret_at_least_32_characters
JWT_EXPIRES_IN=7d

# Email Service
RESEND_API_KEY=re_xxxxxxxxxxxx
EMAIL_FROM=DigiWebDex <noreply@digiwebdex.com>
ADMIN_EMAIL=digiwebdex@gmail.com

# SMS Service (optional)
SMS_API_KEY=
SMS_SENDER_ID=DigiWebDex

# Security
WEBHOOK_SECRET=your_webhook_secret_here
CRON_SECRET=your_cron_secret_here

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# Monitoring (optional)
SENTRY_DSN=
LOG_LEVEL=info

# Analytics (optional)
VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX
VITE_FB_PIXEL_ID=XXXXXXXXXX

# Feature Flags
ENABLE_DEBUG_LOGGING=false
ENABLE_RATE_LIMITING=true
ENABLE_AUDIT_LOGGING=true
