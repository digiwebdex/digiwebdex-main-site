# Digiwebdex Production Environment Template
# Copy this file to .env.production and fill in the values

# Application
NODE_ENV=production
VITE_APP_URL=https://digiwebdex.com

# Supabase (these are public keys - safe to commit)
VITE_SUPABASE_URL=https://qszmmysnwjvywpsofbgs.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your_anon_key_here
VITE_SUPABASE_PROJECT_ID=qszmmysnwjvywpsofbgs

# Security
# Generate with: openssl rand -hex 32
WEBHOOK_SECRET=your_webhook_secret_here
CRON_SECRET=your_cron_secret_here

# Rate Limiting (optional overrides)
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# Monitoring (optional)
SENTRY_DSN=
LOG_LEVEL=info

# Feature Flags
ENABLE_DEBUG_LOGGING=false
ENABLE_RATE_LIMITING=true
ENABLE_AUDIT_LOGGING=true
